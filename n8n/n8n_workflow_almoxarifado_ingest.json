    {
      "parameters": {
        "jsCode": "const snapshotAt = new Date().toISOString();\nconst repoRoot = $env.PCP_REPO_ROOT || '/opt/saars.inplast';\nconst workbookPath = $env.PCP_ALMOX_WORKBOOK || '/data/ingest/Estoque Almoxarifado.xlsx';\nreturn [\n  {\n    json: {\n      source_code: 'estoque_materia_prima_almoxarifado',\n      parser_path: `${repoRoot}/parsers/parse_estoque_almoxarifado_mp.py`,\n      runner_path: `${repoRoot}/parsers/run_inventory_parser.py`,\n      workbook_path: workbookPath,\n      snapshot_at: snapshotAt,\n      workflow_name: 'PCP | 12 | Almoxarifado | Ingestao'\n    }\n  },\n  {\n    json: {\n      source_code: 'estoque_componente_almoxarifado',\n      parser_path: `${repoRoot}/parsers/parse_estoque_almoxarifado_componentes.py`,\n      runner_path: `${repoRoot}/parsers/run_inventory_parser.py`,\n      workbook_path: workbookPath,\n      snapshot_at: snapshotAt,\n      workflow_name: 'PCP | 12 | Almoxarifado | Ingestao'\n    }\n  }\n];"
      },
      "id": "build-source-queue",
      "name": "Build Source Queue",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -620,
        140
      ]
    },
    {
      "parameters": {
        "command": "=python3 \"{{$json.runner_path}}\" --source-code \"{{$json.source_code}}\" --parser-path \"{{$json.parser_path}}\" --workbook-path \"{{$json.workbook_path}}\" --snapshot-at \"{{$json.snapshot_at}}\" --workflow-name \"{{$json.workflow_name}}\""
      },
      "id": "run-parser-envelope",
      "name": "Run Parser Envelope",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
