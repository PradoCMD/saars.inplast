        140
      ]
    },
    {
      "parameters": {
        "jsCode": "const payload = JSON.parse($json.stdout || '{}');\nreturn [{ json: payload }];"
      },
      "id": "parse-envelope",
      "name": "Parse Envelope",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -120,
        140
      ]
    },
    {
      "parameters": {
        "jsCode": "const esc = (value) => JSON.stringify(value ?? {}).replace(/'/g, \"''\");\nconst escText = (value) => String(value ?? '').replace(/'/g, \"''\");\nconst sql = `select ops.ingest_inventory_payload(\\n  '${escText($json.source_code)}',\\n  '${escText($json.snapshot_at)}'::timestamptz,\\n  '${esc($json.records)}'::jsonb,\\n  '${esc($json.meta)}'::jsonb\\n) as run_id;`;\nreturn [{ json: { ...$json, sql_query: sql } }];"
      },
      "id": "build-sql",
      "name": "Build SQL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        120,
        140
      ]
    },
