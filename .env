# =============================================================================
# PCP SaaS — Inplast | Arquivo de referência de variáveis de ambiente
# =============================================================================
# NÃO crie um .env manual a menos que realmente precise mudar algo.
# Em modo mock (desenvolvimento local) o servidor funciona SEM nenhum .env.
# Só crie um .env se for rodar modo postgres localmente.
#
# Para rodar em modo mock (sem banco):
#   python3 server.py
#   (PCP_DATA_MODE padrão é "mock", porta padrão é 8765)
#
# Para rodar em modo postgres local, copie este arquivo:
#   cp .env.example .env
#   Preencha as senhas reais e rode:
#   PCP_DATA_MODE=postgres python3 server.py
# =============================================================================

PCP_HOST=127.0.0.1
PCP_PORT=8765
PCP_DATA_MODE=postgres

# --- Banco de Dados Postgres ---
PCP_POSTGRES_HOST=127.0.0.1
PCP_POSTGRES_INTERNAL_PORT=55432
PCP_POSTGRES_PORT=55432
PCP_POSTGRES_DB=inplast_pcp
PCP_POSTGRES_SUPERUSER=postgres
PCP_POSTGRES_SUPERPASSWORD=CHANGE_ME_POSTGRES

PCP_APP_DB_PASSWORD=CHANGE_ME_PCP_APP
PCP_INTEGRATION_DB_PASSWORD=CHANGE_ME_PCP_INTEGRATION

PCP_DATABASE_URL=postgresql://pcp_app:CHANGE_ME_PCP_APP@127.0.0.1:55432/inplast_pcp
PCP_ACTIONS_DATABASE_URL=postgresql://pcp_integration:CHANGE_ME_PCP_INTEGRATION@127.0.0.1:55432/inplast_pcp

# --- Fontes Google Sheets (formato correto: pub?output=xlsx) ---
# IMPORTANTE: usar /pub?output=xlsx, NUNCA /pubhtml?widget=true&headers=false
PCP_ACABADO_PUBLISHED_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vRIlcxI2E0BRlf4i2M49MIW5XiLx69xWwkrLmst0Fs5HW5gSlk-wf8wAVjur7FH1mQRz_-qmUvZGJND/pub?output=xlsx
PCP_INTERMEDIARIO_PUBLISHED_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vSs-C_7_vu6L1lq9ScJEcQNT3F23en4MdgHBUI2FFkqBm9c_Zq8WHdtZuXkMhQvcegp05KewJQzPlCP/pub?output=xlsx
PCP_ALMOX_PUBLISHED_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vTTPIHy6_gEBngeXzFQQGvPdCxNPeBP_le2etDdbTPTbF8XcGRPiuzVT5QSa1YRQsLQFb_7GiFNKCFa/pub?output=xlsx

# --- Integração Sankhya ---
SANKHYA_AUTHORIZATION=Bearer CHANGE_ME_SANKHYA_TOKEN
SANKHYA_CODIGO_EMPRESA=INPLAST
SANKHYA_ORDENS_CARGA_LIST_URL=https://api.sankhya.com.br/v1/logistica/ordens-carga
SANKHYA_ORDENS_CARGA_DETAIL_URL_TEMPLATE=https://api.sankhya.com.br/v1/logistica/empresas/{codigoEmpresa}/ordens-carga/{codigoOrdemCarga}

# --- Autenticação PCP ---
PCP_AUTH_TOKEN_SECRET=CHANGE_ME_AUTH_SECRET_LONGA_E_ALEATORIA
PCP_AUTH_TOKEN_TTL_SECONDS=28800

# --- Webhooks n8n (opcional) ---
# PCP_N8N_ROMANEIOS_WEBHOOK_URL=https://seu-n8n.com/webhook/romaneios
# PCP_N8N_ROMANEIOS_WEBHOOK_TOKEN=CHANGE_ME
